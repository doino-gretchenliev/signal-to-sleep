# Signal-to-Sleep environment configuration
# Copy to .env or run `make init` to auto-generate with a random MQTT password.

# MQTT credentials (must match mosquitto/passwd)
MQTT_USERNAME=sleeptracker
MQTT_PASSWORD=

# MQTT broker settings
MQTT_BROKER=mosquitto
MQTT_PORT=1884
MQTT_TOPIC=sensor-logger
MQTT_COMMAND_TOPIC=sensor-logger/command

# Web dashboard
WEB_PORT=8080

# Database
DATABASE_PATH=/app/db/sleep_data.db
